{
	"name": "seedcli",
	"version": "1.0.1",
	"description": "Batteries-included, modular, TypeScript-first CLI framework powered by Node.js",
	"license": "MIT",
	"author": "Rully Ardiansyah <rully@dreamshive.io>",
	"repository": {
		"type": "git",
		"url": "https://github.com/SeedCLI/seed"
	},
	"homepage": "https://seedcli.dev",
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.26.2",
	"private": true,
	"scripts": {
		"build": "node --import tsx scripts/build.ts",
		"build:clean": "node --import tsx scripts/build.ts --clean",
		"build:dist": "node --import tsx scripts/build-dist.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"publish:dry": "node --import tsx scripts/publish.ts --dry-run",
		"publish:npm": "node --import tsx scripts/publish.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@hakobu/hakobu": "^1.0.0",
		"@types/node": "^24",
		"esbuild": "^0.27.4",
		"execa": "^9",
		"openapi-fetch": "^0.17.0",
		"smol-toml": "^1",
		"tinyglobby": "^0.2",
		"tsx": "^4",
		"typescript": "5.9.3",
		"vitest": "^3"
	}
}
