{
	"name": "@seedcli/tui-vue",
	"version": "1.0.0",
	"description": "Vue custom renderer for Seed CLI TUI apps",
	"type": "module",
	"license": "MIT",
	"author": "Rully Ardiansyah <rully@dreamshive.io>",
	"repository": {
		"type": "git",
		"url": "https://github.com/SeedCLI/seed",
		"directory": "packages/tui-vue"
	},
	"homepage": "https://seedcli.dev",
	"keywords": [
		"cli",
		"tui",
		"terminal",
		"vue",
		"renderer",
		"reconciler"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
