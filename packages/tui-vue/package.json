			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"LICENSE"
	],
	"dependencies": {
		"@seedcli/tui-core": "workspace:*",
		"@seedcli/tui": "workspace:*",
		"@vue/runtime-core": "^3.5.29",
		"vue": "^3.5.29"
	},
	"peerDependencies": {
		"vue": ">=3.4.0"
	}
}
