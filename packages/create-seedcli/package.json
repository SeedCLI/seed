{
	"name": "create-seedcli",
	"version": "1.1.4",
	"description": "Scaffold a new Seed CLI project — works with npx and npm create",
	"type": "module",
	"license": "MIT",
	"author": "Rully Ardiansyah <rully@dreamshive.io>",
	"repository": {
		"type": "git",
		"url": "https://github.com/SeedCLI/seed",
		"directory": "packages/create-seedcli"
	},
	"homepage": "https://seedcli.dev",
	"keywords": [
		"cli",
		"scaffold",
		"create",
		"seed",
		"node",
		"npx",
		"typescript"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"create-seedcli": "./dist/index.js"
	},
	"files": [
		"dist",
		"LICENSE",
		"templates"
	],
	"dependencies": {
		"@seedcli/filesystem": "workspace:*",
		"@seedcli/package-manager": "workspace:*",
		"@seedcli/print": "workspace:*",
		"@seedcli/prompt": "workspace:*",
		"@seedcli/strings": "workspace:*",
		"@seedcli/system": "workspace:*",
		"@seedcli/template": "workspace:*"
	},
	"devDependencies": {
		"@seedcli/testing": "workspace:*"
	}
}
