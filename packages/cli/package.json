{
	"name": "@seedcli/cli",
	"version": "1.1.0",
	"description": "Scaffolding CLI for creating and managing Seed CLI projects",
	"type": "module",
	"license": "MIT",
	"author": "Rully Ardiansyah <rully@dreamshive.io>",
	"repository": {
		"type": "git",
		"url": "https://github.com/SeedCLI/seed",
		"directory": "packages/cli"
	},
	"homepage": "https://seedcli.dev",
	"keywords": [
		"cli",
		"scaffold",
		"create",
		"generate",
		"seed",
		"node"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"seed": "./dist/index.js"
	},
	"files": [
		"dist",
		"LICENSE",
		"templates"
	],
	"dependencies": {
		"@hakobu/hakobu": "^1.0.0",
		"@seedcli/config": "workspace:*",
		"@seedcli/core": "workspace:*",
		"@seedcli/filesystem": "workspace:*",
		"@seedcli/package-manager": "workspace:*",
		"@seedcli/print": "workspace:*",
		"@seedcli/prompt": "workspace:*",
		"@seedcli/strings": "workspace:*",
		"@seedcli/system": "workspace:*",
		"@seedcli/template": "workspace:*",
		"execa": "^9.0.0",
		"tinyglobby": "^0.2.0"
	},
	"devDependencies": {}
}
