{
	"name": "@seedcli/core",
	"version": "1.1.1",
	"description": "Core runtime, builder API, command system, and arg parser for Seed CLI",
	"type": "module",
	"license": "MIT",
	"author": "Rully Ardiansyah <rully@dreamshive.io>",
	"repository": {
		"type": "git",
		"url": "https://github.com/SeedCLI/seed",
		"directory": "packages/core"
	},
	"homepage": "https://seedcli.dev",
	"keywords": [
		"cli",
		"framework",
		"command",
		"args",
		"parser",
		"node",
		"typescript"
	],
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"LICENSE"
	],
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@seedcli/completions": "workspace:*",
		"@seedcli/config": "workspace:*",
		"@seedcli/filesystem": "workspace:*",
		"@seedcli/http": "workspace:*",
		"@seedcli/package-manager": "workspace:*",
		"@seedcli/patching": "workspace:*",
		"@seedcli/print": "workspace:*",
		"@seedcli/prompt": "workspace:*",
		"@seedcli/semver": "workspace:*",
		"@seedcli/strings": "workspace:*",
		"@seedcli/system": "workspace:*",
		"@seedcli/template": "workspace:*",
		"@seedcli/ui": "workspace:*",
		"tinyglobby": "^0.2.13"
	},
	"devDependencies": {
		"@seedcli/testing": "workspace:*"
	}
}
